Public Sub Todoを追加()
    Dim wsInput As Worksheet
    Dim todoTable As ListObject
    Dim todoDateValue As Variant
    Dim actualDateValue As Variant
    Dim itemNoValue As Variant
    Dim taskText As String
    Dim taskId As Long
    Dim previousState As TExcelState
    Dim stateWasChanged As Boolean
    Dim dataWasSaved As Boolean
    Dim completed As Boolean
    Dim failed As Boolean
    Dim savedErrorNumber As Long
    Dim savedErrorDescription As String

    On Error GoTo ErrHandler

    If Not 必要なシートとテーブルがある Then
        MsgBox "先に「初期設定」を実行して。", vbExclamation, "ToDo管理"
        Exit Sub
    End If

    Set wsInput = ThisWorkbook.Worksheets(INPUT_SHEET_NAME)
    todoDateValue = wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Value
    actualDateValue = wsInput.Cells(INPUT_ROW, COL_ACTUAL_DATE).Value
    itemNoValue = wsInput.Cells(INPUT_ROW, COL_NO).Value
    taskText = セルの文字列(wsInput.Cells(INPUT_ROW, COL_TASK).Value)

    If セルの文字列(todoDateValue) = vbNullString Then
        MsgBox "ToDo納期を選んで。", vbExclamation, "ToDo管理"
        Exit Sub
    End If

    If Not IsDate(todoDateValue) Then
        MsgBox "ToDo納期が日付になっていない。", vbExclamation, "ToDo管理"
        Exit Sub
    End If

    If セルの文字列(actualDateValue) <> vbNullString Then
        If Not IsDate(actualDateValue) Then
            MsgBox "実納期が日付になっていない。", vbExclamation, "ToDo管理"
            Exit Sub
        End If
    End If

    If taskText = vbNullString Then
        MsgBox "「行うこと」を入力して。", vbExclamation, "ToDo管理"
        Exit Sub
    End If

    Excel処理を開始 previousState
    stateWasChanged = True

    taskId = ToDoを登録する(todoDateValue, actualDateValue, itemNoValue, taskText)
    dataWasSaved = (taskId > 0)

    ' 登録に成功したあとで入力欄を空にする。
    wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Resize(1, 4).ClearContents

    Set todoTable = テーブルを取得( _
        ThisWorkbook.Worksheets(TODO_SHEET_NAME), _
        TODO_TABLE_NAME _
    )
    納期順に並び替える todoTable
    表示を更新

    wsInput.Activate
    wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Select
    completed = True

ExitPoint:
    If stateWasChanged Then Excel処理を終了 previousState

    If failed Then
        If dataWasSaved Then
            savedErrorDescription = _
                "ToDo自体はID " & taskId & "として保存済み。" & vbCrLf & _
                "画面更新で問題が起きた: " & savedErrorDescription
        End If
        エラーを通知 "ToDo追加", savedErrorNumber, savedErrorDescription
    ElseIf completed Then
        MsgBox "ToDoリストに追加した。", vbInformation, "ToDo管理"
    End If
    Exit Sub

ErrHandler:
    savedErrorNumber = Err.Number
    savedErrorDescription = Err.Description
    failed = True
    Resume ExitPoint
End Sub

