' 共通処理
Private Type TExcelState
    ScreenUpdating As Boolean
    EnableEvents As Boolean
    DisplayAlerts As Boolean
    Calculation As XlCalculation
End Type

Private Sub Excel処理を開始(ByRef previousState As TExcelState)
    ' 呼び出し前の状態を保存し、終了時に必ず元へ戻す。
    With Application
        previousState.ScreenUpdating = .ScreenUpdating
        previousState.EnableEvents = .EnableEvents
        previousState.DisplayAlerts = .DisplayAlerts
        previousState.Calculation = .Calculation

        .ScreenUpdating = False
        .EnableEvents = False
        .DisplayAlerts = False
        .Calculation = xlCalculationManual
    End With
End Sub

Private Sub Excel処理を終了(ByRef previousState As TExcelState)
    With Application
        .Calculation = previousState.Calculation
        .DisplayAlerts = previousState.DisplayAlerts
        .EnableEvents = previousState.EnableEvents
        .ScreenUpdating = previousState.ScreenUpdating
    End With
End Sub

Private Function シートがある(ByVal sheetName As String) As Boolean
    Dim ws As Worksheet

    On Error Resume Next
    Set ws = ThisWorkbook.Worksheets(sheetName)
    On Error GoTo 0

    シートがある = Not ws Is Nothing
End Function

Private Function 必要なシートがある() As Boolean
    必要なシートがある = _
        シートがある(INPUT_SHEET_NAME) And _
        シートがある(TODO_SHEET_NAME) And _
        シートがある(DONE_SHEET_NAME) And _
        シートがある(DAILY_SHEET_NAME)
End Function

Private Function シートを用意(ByVal targetName As String) As Worksheet
    Dim ws As Worksheet
    Dim resultSheet As Worksheet

    On Error Resume Next
    Set resultSheet = ThisWorkbook.Worksheets(targetName)
    On Error GoTo 0

    If Not resultSheet Is Nothing Then
        Set シートを用意 = resultSheet
        Exit Function
    End If

    ' 新しいブックでは、最初からある空シートを再利用する。
    For Each ws In ThisWorkbook.Worksheets
        If Not ToDo用の名前か(ws.Name) Then
            If シートが空(ws) Then
                ws.Name = targetName
                Set シートを用意 = ws
                Exit Function
            End If
        End If
    Next ws

    Set resultSheet = ThisWorkbook.Worksheets.Add( _
        After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count) _
    )
    resultSheet.Name = targetName
    Set シートを用意 = resultSheet
End Function

Private Function シートが空(ByVal ws As Worksheet) As Boolean
    シートが空 = _
        (Application.WorksheetFunction.CountA(ws.UsedRange) = 0) And _
        (ws.Shapes.Count = 0)
End Function

Private Function ToDo用の名前か(ByVal sheetName As String) As Boolean
    ToDo用の名前か = _
        (sheetName = INPUT_SHEET_NAME) Or _
        (sheetName = TODO_SHEET_NAME) Or _
        (sheetName = DONE_SHEET_NAME) Or _
        (sheetName = DAILY_SHEET_NAME) Or _
        (sheetName = LOG_SHEET_NAME)
End Function

Private Function テーブルを取得( _
    ByVal ws As Worksheet, _
    ByVal tableName As String _
) As ListObject
    On Error Resume Next
    Set テーブルを取得 = ws.ListObjects(tableName)
    On Error GoTo 0
End Function

Private Function マクロ名を作る(ByVal procedureName As String) As String
    ' ブック名にアポストロフィがあっても、OnActionで正しく呼べる形にする。
    マクロ名を作る = "'" & Replace(ThisWorkbook.Name, "'", "''") & "'!" & procedureName
End Function

Private Function セルの文字列(ByVal sourceValue As Variant) As String
    If IsError(sourceValue) Or IsEmpty(sourceValue) Or IsNull(sourceValue) Then Exit Function
    セルの文字列 = Trim$(CStr(sourceValue))
End Function

Private Sub エラーを通知( _
    ByVal procedureName As String, _
    ByVal errorNumber As Long, _
    ByVal errorDescription As String _
)
    エラーを記録 procedureName, errorNumber, errorDescription

    MsgBox _
        procedureName & "で処理が止まった。" & vbCrLf & _
        "エラー " & errorNumber & ": " & errorDescription, _
        vbExclamation, _
        "ToDo管理"
End Sub

Private Sub エラーを記録( _
    ByVal procedureName As String, _
    ByVal errorNumber As Long, _
    ByVal errorDescription As String _
)
    Dim ws As Worksheet
    Dim nextRow As Long

    ' エラー記録自体が失敗しても、本来のエラー処理を妨げない。
    On Error Resume Next

    Set ws = ThisWorkbook.Worksheets(LOG_SHEET_NAME)
    If ws Is Nothing Then
        Set ws = ThisWorkbook.Worksheets.Add( _
            After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count) _
        )
        ws.Name = LOG_SHEET_NAME
        ws.Cells(1, 1).Value = LOG_HEADER_DATE
        ws.Cells(1, 2).Value = LOG_HEADER_PROCEDURE
        ws.Cells(1, 3).Value = LOG_HEADER_NUMBER
        ws.Cells(1, 4).Value = LOG_HEADER_DESCRIPTION
        ws.Range("A1:D1").Font.Bold = True
        ws.Columns("A").NumberFormat = "yyyy/mm/dd hh:mm:ss"
        ws.Columns("A:D").EntireColumn.AutoFit
    End If

    nextRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row + 1
    If nextRow < 2 Then nextRow = 2

    ws.Cells(nextRow, 1).Value = Now
    ws.Cells(nextRow, 2).Value = procedureName
    ws.Cells(nextRow, 3).Value = errorNumber
    ws.Cells(nextRow, 4).Value = errorDescription
    ws.Visible = xlSheetHidden

    On Error GoTo 0
End Sub

' データ処理
Private Sub データ構造を用意( _
    ByVal wsTodo As Worksheet, _
    ByVal wsDone As Worksheet, _
    ByVal wsDaily As Worksheet _
)
    Dim todoTable As ListObject
    Dim doneTable As ListObject
    Dim dailyTable As ListObject
    Dim seenIds As Collection
    Dim nextId As Long

    Set todoTable = 一覧テーブルを用意(wsTodo, TODO_TABLE_NAME)
    Set doneTable = 一覧テーブルを用意(wsDone, DONE_TABLE_NAME)
    Set dailyTable = 毎日業務テーブルを用意(wsDaily)

    空の一覧行を除く todoTable, False
    空の一覧行を除く doneTable, False
    空の一覧行を除く dailyTable, True

    nextId = 最大ID(todoTable, doneTable, dailyTable) + 1
    If nextId < 1 Then nextId = 1

    Set seenIds = New Collection
    IDを整える todoTable, seenIds, nextId
    IDを整える doneTable, seenIds, nextId
    IDを整える dailyTable, seenIds, nextId

    todoTable.ListColumns(HEADER_ID).Range.NumberFormat = "0"
    doneTable.ListColumns(HEADER_ID).Range.NumberFormat = "0"
    dailyTable.ListColumns(HEADER_ID).Range.NumberFormat = "0"
End Sub

Private Function 一覧テーブルを用意( _
    ByVal ws As Worksheet, _
    ByVal tableName As String _
) As ListObject
    Dim tableObject As ListObject
    Dim lastRow As Long

    一覧見出しを設定 ws
    Set tableObject = 既存テーブルを探す(ws, tableName, COL_CHECK)

    If tableObject Is Nothing Then
        lastRow = 最終使用行(ws, COL_CHECK)
        If lastRow < FIRST_DATA_ROW Then lastRow = FIRST_DATA_ROW

        Set tableObject = ws.ListObjects.Add( _
            SourceType:=xlSrcRange, _
            Source:=ws.Range( _
                ws.Cells(HEADER_ROW, COL_ID), _
                ws.Cells(lastRow, COL_CHECK) _
            ), _
            XlListObjectHasHeaders:=xlYes _
        )
        tableObject.Name = tableName
    End If

    一覧見出しを設定 ws
    tableObject.ShowTableStyleFirstColumn = False
    tableObject.ShowTableStyleLastColumn = False
    tableObject.ShowTableStyleRowStripes = False
    tableObject.TableStyle = "TableStyleLight9"

    Set 一覧テーブルを用意 = tableObject
End Function

Private Function 毎日業務テーブルを用意(ByVal ws As Worksheet) As ListObject
    Dim tableObject As ListObject
    Dim lastRow As Long

    毎日業務見出しを設定 ws
    Set tableObject = 既存テーブルを探す(ws, DAILY_TABLE_NAME, COL_DAILY_LAST_DATE)

    If tableObject Is Nothing Then
        lastRow = 最終使用行(ws, COL_DAILY_LAST_DATE)
        If lastRow < FIRST_DATA_ROW Then lastRow = FIRST_DATA_ROW

        Set tableObject = ws.ListObjects.Add( _
            SourceType:=xlSrcRange, _
            Source:=ws.Range( _
                ws.Cells(HEADER_ROW, COL_ID), _
                ws.Cells(lastRow, COL_DAILY_LAST_DATE) _
            ), _
            XlListObjectHasHeaders:=xlYes _
        )
        tableObject.Name = DAILY_TABLE_NAME
    End If

    毎日業務見出しを設定 ws
    tableObject.ShowTableStyleFirstColumn = False
    tableObject.ShowTableStyleLastColumn = False
    tableObject.ShowTableStyleRowStripes = False
    tableObject.TableStyle = "TableStyleLight9"

    Set 毎日業務テーブルを用意 = tableObject
End Function

Private Function 既存テーブルを探す( _
    ByVal ws As Worksheet, _
    ByVal expectedName As String, _
    ByVal lastColumn As Long _
) As ListObject
    Dim candidate As ListObject
    Dim namedTable As ListObject

    Set namedTable = テーブルを取得(ws, expectedName)
    If Not namedTable Is Nothing Then
        Set 既存テーブルを探す = namedTable
        Exit Function
    End If

    ' 同じ場所に既存テーブルがある場合は、データを壊さず引き継ぐ。
    For Each candidate In ws.ListObjects
        If candidate.HeaderRowRange.Row = HEADER_ROW Then
            If candidate.Range.Column = COL_ID Then
                If candidate.Range.Columns.Count = lastColumn Then
                    candidate.Name = expectedName
                    Set 既存テーブルを探す = candidate
                    Exit Function
                End If
            End If
        End If
    Next candidate
End Function

