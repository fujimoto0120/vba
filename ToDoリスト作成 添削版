Private Sub 一覧を診断( _
    ByVal tableObject As ListObject, _
    ByVal displayName As String, _
    ByVal isDaily As Boolean, _
    ByVal seenIds As Collection, _
    ByRef issues As String, _
    ByRef issueCount As Long _
)
    Dim listRow As ListRow
    Dim taskId As Long
    Dim statusText As String

    If tableObject Is Nothing Then
        診断結果を追加 issues, issueCount, displayName & "のテーブルがない。"
        Exit Sub
    End If

    If Not 必要な列がある(tableObject, isDaily) Then
        診断結果を追加 issues, issueCount, displayName & "の列構成が違う。"
        Exit Sub
    End If

    For Each listRow In tableObject.ListRows
        taskId = 0

        If Not IsNumeric(listRow.Range.Cells(1, COL_ID).Value2) Then
            診断結果を追加 issues, issueCount, displayName & "に数値でないIDがある。"
        Else
            taskId = CLng(listRow.Range.Cells(1, COL_ID).Value2)
            If taskId < 1 Then
                診断結果を追加 issues, issueCount, displayName & "に無効なIDがある。"
            ElseIf Not 診断用IDを記憶する(seenIds, taskId) Then
                診断結果を追加 issues, issueCount, "ID " & taskId & "が重複している。"
            End If
        End If

        If セルの文字列(listRow.Range.Cells(1, COL_TASK).Value) = vbNullString Then
            診断結果を追加 issues, issueCount, displayName & "に内容が空の行がある。"
        End If

        If isDaily Then
            statusText = セルの文字列(listRow.Range.Cells(1, COL_CHECK).Value)
            If statusText <> vbNullString Then
                If statusText <> DAILY_STATUS_ON And statusText <> DAILY_STATUS_OFF Then
                    診断結果を追加 _
                        issues, _
                        issueCount, _
                        displayName & "のID " & taskId & "の状態が正しくない。"
                End If
            End If
        Else
            If Not IsDate(listRow.Range.Cells(1, COL_TODO_DATE).Value) Then
                診断結果を追加 _
                    issues, _
                    issueCount, _
                    displayName & "のID " & taskId & "の納期が日付ではない。"
            End If
        End If
    Next listRow
End Sub

Private Function 必要な列がある( _
    ByVal tableObject As ListObject, _
    ByVal isDaily As Boolean _
) As Boolean
    Dim requiredLastHeader As String

    On Error GoTo MissingColumn

    If isDaily Then
        If tableObject.ListColumns.Count <> COL_DAILY_LAST_DATE Then GoTo MissingColumn
    Else
        If tableObject.ListColumns.Count <> COL_CHECK Then GoTo MissingColumn
    End If

    requiredLastHeader = tableObject.ListColumns(HEADER_ID).Name
    requiredLastHeader = tableObject.ListColumns(HEADER_TODO_DATE).Name
    requiredLastHeader = tableObject.ListColumns(HEADER_ACTUAL_DATE).Name
    requiredLastHeader = tableObject.ListColumns(HEADER_NO).Name
    requiredLastHeader = tableObject.ListColumns(HEADER_TASK).Name

    If isDaily Then
        requiredLastHeader = tableObject.ListColumns(HEADER_STATUS).Name
        requiredLastHeader = tableObject.ListColumns(HEADER_LAST_ADDED_DATE).Name
    Else
        requiredLastHeader = tableObject.ListColumns(HEADER_CHECK).Name
    End If

    必要な列がある = True
    Exit Function

MissingColumn:
    必要な列がある = False
End Function

Private Function 診断用IDを記憶する( _
    ByVal seenIds As Collection, _
    ByVal taskId As Long _
) As Boolean
    On Error Resume Next
    seenIds.Add True, "ID_" & CStr(taskId)
    診断用IDを記憶する = (Err.Number = 0)
    Err.Clear
    On Error GoTo 0
End Function

Private Sub 診断結果を追加( _
    ByRef issues As String, _
    ByRef issueCount As Long, _
    ByVal message As String _
)
    issueCount = issueCount + 1
    If issueCount <= 20 Then
        If Len(issues) > 0 Then issues = issues & vbCrLf
        issues = issues & "・" & message
    End If
End Sub


