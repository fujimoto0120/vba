Public Sub チェック切替()
    Dim callerName As String
    Dim taskId As Long
    Dim todoTable As ListObject
    Dim doneTable As ListObject
    Dim sourceTable As ListObject
    Dim targetTable As ListObject
    Dim foundRow As ListRow
    Dim previousState As TExcelState
    Dim stateWasChanged As Boolean
    Dim dataWasMoved As Boolean
    Dim failed As Boolean
    Dim savedErrorNumber As Long
    Dim savedErrorDescription As String

    On Error GoTo ErrHandler

    callerName = CStr(Application.Caller)
    If Left$(callerName, Len(CHECKBOX_PREFIX)) <> CHECKBOX_PREFIX Then Exit Sub

    taskId = CLng(Val(Mid$(callerName, Len(CHECKBOX_PREFIX) + 1)))
    If taskId < 1 Then Exit Sub

    Set todoTable = テーブルを取得( _
        ThisWorkbook.Worksheets(TODO_SHEET_NAME), _
        TODO_TABLE_NAME _
    )
    Set doneTable = テーブルを取得( _
        ThisWorkbook.Worksheets(DONE_SHEET_NAME), _
        DONE_TABLE_NAME _
    )

    Set foundRow = IDから行を探す(todoTable, taskId)
    If Not foundRow Is Nothing Then
        Set sourceTable = todoTable
        Set targetTable = doneTable
    Else
        Set foundRow = IDから行を探す(doneTable, taskId)
        If foundRow Is Nothing Then Exit Sub
        Set sourceTable = doneTable
        Set targetTable = todoTable
    End If

    Excel処理を開始 previousState
    stateWasChanged = True

    ToDoを移動する taskId, sourceTable, targetTable
    dataWasMoved = True

    納期順に並び替える sourceTable
    納期順に並び替える targetTable
    表示を更新

ExitPoint:
    If stateWasChanged Then Excel処理を終了 previousState

    If failed Then
        If dataWasMoved Then
            savedErrorDescription = _
                "ToDoの移動は完了済み。" & vbCrLf & _
                "画面更新で問題が起きた: " & savedErrorDescription
        End If
        エラーを通知 "チェック切替", savedErrorNumber, savedErrorDescription
    End If
    Exit Sub

ErrHandler:
    savedErrorNumber = Err.Number
    savedErrorDescription = Err.Description
    failed = True
    Resume ExitPoint
End Sub

Public Sub 設定を診断()
    Dim issues As String
    Dim issueCount As Long
    Dim seenIds As Collection
    Dim todoTable As ListObject
    Dim doneTable As ListObject
    Dim dailyTable As ListObject
    Dim savedErrorNumber As Long
    Dim savedErrorDescription As String

    On Error GoTo ErrHandler

    If Not 必要なシートがある Then
        診断結果を追加 issues, issueCount, "必要な4シートのいずれかがない。"
    Else
        Set todoTable = テーブルを取得( _
            ThisWorkbook.Worksheets(TODO_SHEET_NAME), _
            TODO_TABLE_NAME _
        )
        Set doneTable = テーブルを取得( _
            ThisWorkbook.Worksheets(DONE_SHEET_NAME), _
            DONE_TABLE_NAME _
        )
        Set dailyTable = テーブルを取得( _
            ThisWorkbook.Worksheets(DAILY_SHEET_NAME), _
            DAILY_TABLE_NAME _
        )

        Set seenIds = New Collection
        一覧を診断 todoTable, "ToDoリスト", False, seenIds, issues, issueCount
        一覧を診断 doneTable, "完了済み", False, seenIds, issues, issueCount
        一覧を診断 dailyTable, "毎日行う業務", True, seenIds, issues, issueCount
    End If

    If issueCount = 0 Then
        MsgBox "診断結果: 問題は見つからなかった。", vbInformation, "ToDo管理"
    Else
        If issueCount > 20 Then
            issues = issues & vbCrLf & "ほか " & (issueCount - 20) & "件"
        End If
        MsgBox _
            "診断結果: " & issueCount & "件の確認事項がある。" & vbCrLf & vbCrLf & issues, _
            vbExclamation, _
            "ToDo管理"
    End If
    Exit Sub

ErrHandler:
    savedErrorNumber = Err.Number
    savedErrorDescription = Err.Description
    エラーを通知 "設定診断", savedErrorNumber, savedErrorDescription
End Sub

