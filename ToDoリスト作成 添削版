Private Sub チェック欄を同期( _
    ByVal ws As Worksheet, _
    ByVal tableObject As ListObject, _
    ByVal isDone As Boolean _
)
    Dim checkNo As Long
    Dim listRow As ListRow
    Dim targetCell As Range
    Dim box As CheckBox
    Dim matchedRow As ListRow
    Dim taskId As Long
    Dim boxName As String
    Dim expectedName As String

    If tableObject Is Nothing Then Exit Sub

    ' データがなくなったチェックボックスと、旧形式の名前を持つものだけを消す。
    For checkNo = ws.CheckBoxes.Count To 1 Step -1
        boxName = ws.CheckBoxes(checkNo).Name
        If Left$(boxName, Len(CHECKBOX_PREFIX)) = CHECKBOX_PREFIX Then
            taskId = CLng(Val(Mid$(boxName, Len(CHECKBOX_PREFIX) + 1)))
            expectedName = CHECKBOX_PREFIX & Format$(taskId, "0000000000")
            Set matchedRow = IDから行を探す(tableObject, taskId)

            If matchedRow Is Nothing Or boxName <> expectedName Then
                ws.CheckBoxes(checkNo).Delete
            End If
            Set matchedRow = Nothing
        End If
    Next checkNo

    For Each listRow In tableObject.ListRows
        taskId = CLng(listRow.Range.Cells(1, COL_ID).Value2)
        boxName = CHECKBOX_PREFIX & Format$(taskId, "0000000000")
        Set targetCell = listRow.Range.Cells(1, COL_CHECK)
        Set box = Nothing

        On Error Resume Next
        Set box = ws.CheckBoxes(boxName)
        On Error GoTo 0

        If box Is Nothing Then
            Set box = ws.CheckBoxes.Add( _
                targetCell.Left + (targetCell.Width - CHECKBOX_SIZE) / 2, _
                targetCell.Top + (targetCell.Height - CHECKBOX_SIZE) / 2, _
                CHECKBOX_SIZE, _
                CHECKBOX_SIZE _
            )
            box.Name = boxName
        End If

        With box
            .Caption = vbNullString
            .OnAction = マクロ名を作る("チェック切替")
            .Placement = xlMoveAndSize
            .Left = targetCell.Left + (targetCell.Width - CHECKBOX_SIZE) / 2
            .Top = targetCell.Top + (targetCell.Height - CHECKBOX_SIZE) / 2
            .Width = CHECKBOX_SIZE
            .Height = CHECKBOX_SIZE
            If isDone Then
                .Value = xlOn
            Else
                .Value = xlOff
            End If
        End With
    Next listRow
End Sub

