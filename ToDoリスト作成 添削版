Private Sub 空の一覧行を除く( _
    ByVal tableObject As ListObject, _
    ByVal isDailyTable As Boolean _
)
    Dim rowNo As Long
    Dim businessColumnCount As Long

    If tableObject.ListRows.Count = 0 Then Exit Sub

    If isDailyTable Then
        businessColumnCount = COL_DAILY_LAST_DATE - COL_TODO_DATE + 1
    Else
        businessColumnCount = COL_TASK - COL_TODO_DATE + 1
    End If

    For rowNo = tableObject.ListRows.Count To 1 Step -1
        If Application.WorksheetFunction.CountA( _
            tableObject.ListRows(rowNo).Range.Cells(1, COL_TODO_DATE).Resize( _
                1, _
                businessColumnCount _
            ) _
        ) = 0 Then
            tableObject.ListRows(rowNo).Delete
        End If
    Next rowNo
End Sub

Private Sub IDを整える( _
    ByVal tableObject As ListObject, _
    ByVal seenIds As Collection, _
    ByRef nextId As Long _
)
    Dim listRow As ListRow
    Dim currentId As Long
    Dim needsNewId As Boolean

    For Each listRow In tableObject.ListRows
        needsNewId = False

        If Not IsNumeric(listRow.Range.Cells(1, COL_ID).Value2) Then
            needsNewId = True
        Else
            currentId = CLng(listRow.Range.Cells(1, COL_ID).Value2)
            If currentId < 1 Then needsNewId = True
        End If

        If Not needsNewId Then
            If Not IDを記憶する(seenIds, currentId) Then needsNewId = True
        End If

        If needsNewId Then
            Do While Not IDを記憶する(seenIds, nextId)
                nextId = nextId + 1
            Loop

            listRow.Range.Cells(1, COL_ID).Value2 = nextId
            nextId = nextId + 1
        End If
    Next listRow
End Sub

Private Function IDを記憶する( _
    ByVal seenIds As Collection, _
    ByVal taskId As Long _
) As Boolean
    On Error Resume Next
    seenIds.Add True, "ID_" & CStr(taskId)
    IDを記憶する = (Err.Number = 0)
    Err.Clear
    On Error GoTo 0
End Function

Private Function 最大ID( _
    ByVal todoTable As ListObject, _
    ByVal doneTable As ListObject, _
    ByVal dailyTable As ListObject _
) As Long
    Dim result As Long

    result = テーブル内の最大ID(todoTable)
    If テーブル内の最大ID(doneTable) > result Then result = テーブル内の最大ID(doneTable)
    If テーブル内の最大ID(dailyTable) > result Then result = テーブル内の最大ID(dailyTable)

    最大ID = result
End Function

Private Function テーブル内の最大ID(ByVal tableObject As ListObject) As Long
    Dim listRow As ListRow
    Dim currentId As Long

    For Each listRow In tableObject.ListRows
        If IsNumeric(listRow.Range.Cells(1, COL_ID).Value2) Then
            currentId = CLng(listRow.Range.Cells(1, COL_ID).Value2)
            If currentId > テーブル内の最大ID Then テーブル内の最大ID = currentId
        End If
    Next listRow
End Function

Private Function 次のToDoID() As Long
    Dim todoTable As ListObject
    Dim doneTable As ListObject
    Dim dailyTable As ListObject

    Set todoTable = テーブルを取得( _
        ThisWorkbook.Worksheets(TODO_SHEET_NAME), _
        TODO_TABLE_NAME _
    )
    Set doneTable = テーブルを取得( _
        ThisWorkbook.Worksheets(DONE_SHEET_NAME), _
        DONE_TABLE_NAME _
    )
    Set dailyTable = テーブルを取得( _
        ThisWorkbook.Worksheets(DAILY_SHEET_NAME), _
        DAILY_TABLE_NAME _
    )

    次のToDoID = 最大ID(todoTable, doneTable, dailyTable) + 1
    If 次のToDoID < 1 Then 次のToDoID = 1
End Function

Private Function ToDoを登録する( _
    ByVal todoDate As Variant, _
    ByVal actualDate As Variant, _
    ByVal itemNo As Variant, _
    ByVal taskText As String _
) As Long
    Dim todoTable As ListObject
    Dim addedRow As ListRow
    Dim rowWasAdded As Boolean
    Dim taskId As Long
    Dim savedErrorNumber As Long
    Dim savedErrorDescription As String

    On Error GoTo ErrHandler

    Set todoTable = テーブルを取得( _
        ThisWorkbook.Worksheets(TODO_SHEET_NAME), _
        TODO_TABLE_NAME _
    )
    If todoTable Is Nothing Then
        Err.Raise vbObjectError + 2101, "ToDoを登録する", "ToDoテーブルが見つからない。"
    End If

    taskId = 次のToDoID()
    Set addedRow = todoTable.ListRows.Add
    rowWasAdded = True

    With addedRow.Range
        .Cells(1, COL_ID).Value2 = taskId
        .Cells(1, COL_TODO_DATE).Value = todoDate
        .Cells(1, COL_ACTUAL_DATE).Value = actualDate
        .Cells(1, COL_NO).Value = itemNo
        .Cells(1, COL_TASK).Value = taskText
        .Cells(1, COL_CHECK).ClearContents
    End With

    ToDoを登録する = taskId
    Exit Function

ErrHandler:
    savedErrorNumber = Err.Number
    savedErrorDescription = Err.Description

    On Error Resume Next
    If rowWasAdded Then addedRow.Delete
    On Error GoTo 0

    Err.Raise savedErrorNumber, "ToDoを登録する", savedErrorDescription
End Function

Private Function IDから行を探す( _
    ByVal tableObject As ListObject, _
    ByVal taskId As Long _
) As ListRow
    Dim listRow As ListRow

    If tableObject Is Nothing Then Exit Function

    For Each listRow In tableObject.ListRows
        If IsNumeric(listRow.Range.Cells(1, COL_ID).Value2) Then
            If CLng(listRow.Range.Cells(1, COL_ID).Value2) = taskId Then
                Set IDから行を探す = listRow
                Exit Function
            End If
        End If
    Next listRow
End Function

Private Sub ToDoを移動する( _
    ByVal taskId As Long, _
    ByVal sourceTable As ListObject, _
    ByVal targetTable As ListObject _
)
    Dim sourceRow As ListRow
    Dim targetRow As ListRow
    Dim taskData As Variant
    Dim targetWasAdded As Boolean
    Dim sourceWasDeleted As Boolean
    Dim savedErrorNumber As Long
    Dim savedErrorDescription As String

    On Error GoTo ErrHandler

    Set sourceRow = IDから行を探す(sourceTable, taskId)
    If sourceRow Is Nothing Then
        Err.Raise vbObjectError + 2102, "ToDoを移動する", "移動元のToDoが見つからない。"
    End If

    ' IDから行うことまでを一度メモリへ取り、移動先へ完全に書いてから元行を消す。
    taskData = sourceRow.Range.Cells(1, COL_ID).Resize(1, COL_TASK).Value2

    Set targetRow = targetTable.ListRows.Add
    targetWasAdded = True
    targetRow.Range.Cells(1, COL_ID).Resize(1, COL_TASK).Value2 = taskData
    targetRow.Range.Cells(1, COL_CHECK).ClearContents

    If CLng(targetRow.Range.Cells(1, COL_ID).Value2) <> taskId Then
        Err.Raise vbObjectError + 2103, "ToDoを移動する", "移動先の確認に失敗した。"
    End If

    sourceRow.Delete
    sourceWasDeleted = True
    Exit Sub

ErrHandler:
    savedErrorNumber = Err.Number
    savedErrorDescription = Err.Description

    ' 元行が残っている間だけ、追加した行を取り消せる。
    On Error Resume Next
    If targetWasAdded And Not sourceWasDeleted Then targetRow.Delete
    On Error GoTo 0

    Err.Raise savedErrorNumber, "ToDoを移動する", savedErrorDescription
End Sub

Private Sub 納期順に並び替える(ByVal tableObject As ListObject)
    If tableObject Is Nothing Then Exit Sub
    If tableObject.ListRows.Count < 2 Then Exit Sub

    With tableObject.Sort
        .SortFields.Clear
        .SortFields.Add _
            Key:=tableObject.ListColumns(HEADER_TODO_DATE).DataBodyRange, _
            SortOn:=xlSortOnValues, _
            Order:=xlAscending, _
            DataOption:=xlSortNormal
        .Header = xlYes
        .MatchCase = False
        .Orientation = xlTopToBottom
        .Apply
    End With
End Sub

Private Function 毎日業務を追加する() As Long
    Dim dailyTable As ListObject
    Dim todoTable As ListObject
    Dim dailyRow As ListRow
    Dim taskText As String
    Dim statusText As String
    Dim lastAddedValue As Variant
    Dim shouldAdd As Boolean

    Set dailyTable = テーブルを取得( _
        ThisWorkbook.Worksheets(DAILY_SHEET_NAME), _
        DAILY_TABLE_NAME _
    )
    Set todoTable = テーブルを取得( _
        ThisWorkbook.Worksheets(TODO_SHEET_NAME), _
        TODO_TABLE_NAME _
    )

    If dailyTable Is Nothing Or todoTable Is Nothing Then
        Err.Raise vbObjectError + 2104, "毎日業務を追加する", "必要なテーブルが見つからない。"
    End If

    For Each dailyRow In dailyTable.ListRows
        taskText = セルの文字列(dailyRow.Range.Cells(1, COL_TASK).Value)
        If Len(taskText) > 0 Then
            dailyRow.Range.Cells(1, COL_TODO_DATE).Value = Date
            dailyRow.Range.Cells(1, COL_ACTUAL_DATE).Value = Date

            statusText = セルの文字列(dailyRow.Range.Cells(1, COL_CHECK).Value)
            If Len(statusText) = 0 Then
                statusText = DAILY_STATUS_ON
                dailyRow.Range.Cells(1, COL_CHECK).Value = statusText
            End If

            Select Case statusText
                Case DAILY_STATUS_ON
                    shouldAdd = True
                Case DAILY_STATUS_OFF
                    shouldAdd = False
                Case Else
                    shouldAdd = False
                    エラーを記録 _
                        "毎日業務を追加する", _
                        vbObjectError + 2105, _
                        "ID " & dailyRow.Range.Cells(1, COL_ID).Value2 & _
                        " の状態が「有効」「停止」以外なので追加しなかった。"
            End Select

            lastAddedValue = dailyRow.Range.Cells(1, COL_DAILY_LAST_DATE).Value
            If IsDate(lastAddedValue) Then
                If DateValue(lastAddedValue) = Date Then shouldAdd = False
            End If

            If shouldAdd Then
                毎日業務1件を追加する dailyRow, todoTable
                毎日業務を追加する = 毎日業務を追加する + 1
            End If
        End If
    Next dailyRow
End Function

Private Sub 毎日業務1件を追加する( _
    ByVal dailyRow As ListRow, _
    ByVal todoTable As ListObject _
)
    Dim targetRow As ListRow
    Dim targetWasAdded As Boolean
    Dim savedErrorNumber As Long
    Dim savedErrorDescription As String

    On Error GoTo ErrHandler

    Set targetRow = todoTable.ListRows.Add
    targetWasAdded = True

    With targetRow.Range
        .Cells(1, COL_ID).Value2 = 次のToDoID()
        .Cells(1, COL_TODO_DATE).Value = Date
        .Cells(1, COL_ACTUAL_DATE).Value = Date
        .Cells(1, COL_NO).Value = dailyRow.Range.Cells(1, COL_NO).Value
        .Cells(1, COL_TASK).Value = dailyRow.Range.Cells(1, COL_TASK).Value
        .Cells(1, COL_CHECK).ClearContents
    End With

    ' 最終追加日は、ToDoへの登録が完了したあとで更新する。
    dailyRow.Range.Cells(1, COL_DAILY_LAST_DATE).Value = Date
    Exit Sub

ErrHandler:
    savedErrorNumber = Err.Number
    savedErrorDescription = Err.Description

    On Error Resume Next
    If targetWasAdded Then targetRow.Delete
    On Error GoTo 0

    Err.Raise savedErrorNumber, "毎日業務1件を追加する", savedErrorDescription
End Sub

Private Function 期限切れ完了件数() As Long
    Dim doneTable As ListObject
    Dim listRow As ListRow
    Dim dueValue As Variant

    Set doneTable = テーブルを取得( _
        ThisWorkbook.Worksheets(DONE_SHEET_NAME), _
        DONE_TABLE_NAME _
    )
    If doneTable Is Nothing Then Exit Function

    For Each listRow In doneTable.ListRows
        dueValue = listRow.Range.Cells(1, COL_TODO_DATE).Value
        If IsDate(dueValue) Then
            If DateValue(dueValue) < Date Then
                期限切れ完了件数 = 期限切れ完了件数 + 1
            End If
        End If
    Next listRow
End Function

Private Function 期限切れ完了行を削除する() As Long
    Dim doneTable As ListObject
    Dim rowNo As Long
    Dim columnNo As Long
    Dim targetNo As Long
    Dim targetCount As Long
    Dim deletedCount As Long
    Dim targetRows() As Long
    Dim backupData() As Variant
    Dim restoredRow As ListRow
    Dim dueValue As Variant
    Dim savedErrorNumber As Long
    Dim savedErrorDescription As String

    On Error GoTo ErrHandler

    Set doneTable = テーブルを取得( _
        ThisWorkbook.Worksheets(DONE_SHEET_NAME), _
        DONE_TABLE_NAME _
    )
    If doneTable Is Nothing Then
        Err.Raise vbObjectError + 2106, "期限切れ完了行を削除する", "完了テーブルが見つからない。"
    End If

    targetCount = 期限切れ完了件数()
    If targetCount = 0 Then Exit Function

    ReDim targetRows(1 To targetCount)
    ReDim backupData(1 To targetCount, 1 To COL_CHECK)

    ' 削除対象を先にメモリへ控えておく。
    For rowNo = doneTable.ListRows.Count To 1 Step -1
        dueValue = doneTable.ListRows(rowNo).Range.Cells(1, COL_TODO_DATE).Value
        If IsDate(dueValue) Then
            If DateValue(dueValue) < Date Then
                targetNo = targetNo + 1
                targetRows(targetNo) = rowNo

                For columnNo = COL_ID To COL_CHECK
                    backupData(targetNo, columnNo) = _
                        doneTable.ListRows(rowNo).Range.Cells(1, columnNo).Value2
                Next columnNo
            End If
        End If
    Next rowNo

    ' 行番号の大きい順に集めてあるので、そのまま消しても未処理行はずれない。
    For targetNo = 1 To targetCount
        doneTable.ListRows(targetRows(targetNo)).Delete
        deletedCount = deletedCount + 1
    Next targetNo

    期限切れ完了行を削除する = deletedCount
    Exit Function

ErrHandler:
    savedErrorNumber = Err.Number
    savedErrorDescription = Err.Description

    ' 途中で失敗した場合は、この処理内で削除済みのデータを戻す。
    On Error Resume Next
    For targetNo = 1 To deletedCount
        Set restoredRow = doneTable.ListRows.Add
        For columnNo = COL_ID To COL_CHECK
            restoredRow.Range.Cells(1, columnNo).Value2 = backupData(targetNo, columnNo)
        Next columnNo
    Next targetNo
    納期順に並び替える doneTable
    On Error GoTo 0

    Err.Raise savedErrorNumber, "期限切れ完了行を削除する", savedErrorDescription
End Function

Private Function 最終使用行( _
    ByVal ws As Worksheet, _
    ByVal lastColumn As Long _
) As Long
    Dim foundCell As Range

    Set foundCell = ws.Range( _
        ws.Cells(FIRST_DATA_ROW, COL_ID), _
        ws.Cells(ws.Rows.Count, lastColumn) _
    ).Find( _
        What:="*", _
        After:=ws.Cells(FIRST_DATA_ROW, COL_ID), _
        LookIn:=xlFormulas, _
        LookAt:=xlPart, _
        SearchOrder:=xlByRows, _
        SearchDirection:=xlPrevious, _
        MatchCase:=False, _
        SearchFormat:=False _
    )

    If foundCell Is Nothing Then
        最終使用行 = HEADER_ROW
    Else
        最終使用行 = foundCell.Row
    End If
End Function

