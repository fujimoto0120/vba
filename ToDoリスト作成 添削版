Private Sub 日付候補を更新()
    Dim ws As Worksheet
    Dim currentDate As Date
    Dim lastDate As Date
    Dim writeRow As Long
    Dim validationRange As Range
    Dim savedErrorNumber As Long
    Dim savedErrorDescription As String

    On Error GoTo ErrHandler

    Set ws = ThisWorkbook.Worksheets(INPUT_SHEET_NAME)
    ws.Columns(DATE_LIST_COLUMN).Hidden = False

    ws.Range( _
        ws.Cells(DATE_LIST_FIRST_ROW, DATE_LIST_COLUMN), _
        ws.Cells(DATE_LIST_FIRST_ROW + DATE_LIST_CLEAR_ROW_COUNT - 1, DATE_LIST_COLUMN) _
    ).ClearContents

    currentDate = Date
    lastDate = DateAdd("m", 1, Date)
    writeRow = DATE_LIST_FIRST_ROW

    Do While currentDate <= lastDate
        ws.Cells(writeRow, DATE_LIST_COLUMN).Value = currentDate
        ws.Cells(writeRow, DATE_LIST_COLUMN).NumberFormat = DATE_DISPLAY_FORMAT
        currentDate = DateAdd("d", 1, currentDate)
        writeRow = writeRow + 1
    Loop

    Set validationRange = ws.Cells(INPUT_ROW, COL_TODO_DATE).Resize(1, 2)
    With validationRange.Validation
        .Delete
        .Add Type:=xlValidateList, _
             AlertStyle:=xlValidAlertStop, _
             Operator:=xlBetween, _
             Formula1:="=" & _
                 ws.Cells(DATE_LIST_FIRST_ROW, DATE_LIST_COLUMN).Address & ":" & _
                 ws.Cells(writeRow - 1, DATE_LIST_COLUMN).Address
        .IgnoreBlank = True
        .InCellDropdown = True
        .InputTitle = "日付を選択"
        .InputMessage = "本日から1か月後まで"
        .ErrorTitle = "日付を確認"
        .ErrorMessage = "プルダウンの日付から選んで。"
        .ShowError = True
    End With

    validationRange.NumberFormat = DATE_DISPLAY_FORMAT
    ws.Columns(DATE_LIST_COLUMN).Hidden = True
    Exit Sub

ErrHandler:
    savedErrorNumber = Err.Number
    savedErrorDescription = Err.Description

    ' 途中で失敗しても、内部用の日付列は表示されたままにしない。
    On Error Resume Next
    If Not ws Is Nothing Then ws.Columns(DATE_LIST_COLUMN).Hidden = True
    On Error GoTo 0

    Err.Raise savedErrorNumber, "日付候補を更新", savedErrorDescription
End Sub

