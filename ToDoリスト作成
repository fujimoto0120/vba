Public Sub 初期設定()
    Dim wsInput As Worksheet
    Dim wsTodo As Worksheet
    Dim wsDone As Worksheet
    Dim wsDaily As Worksheet
    Dim dailyAddCount As Long

    On Error GoTo ErrHandler

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    Set wsInput = シートを用意(INPUT_SHEET_NAME)
    Set wsTodo = シートを用意(TODO_SHEET_NAME)
    Set wsDone = シートを用意(DONE_SHEET_NAME)
    Set wsDaily = シートを用意(DAILY_SHEET_NAME)

    wsInput.Move Before:=ThisWorkbook.Worksheets(1)
    wsTodo.Move After:=wsInput
    wsDone.Move After:=wsTodo
    wsDaily.Move After:=wsDone

    入力シートの体裁を作る wsInput
    一覧シートの体裁を作る wsTodo, False
    一覧シートの体裁を作る wsDone, True
    毎日業務シートの体裁を作る wsDaily

    日付候補を更新
    追加ボタンを作る
    削除ボタンを作る
    毎日業務ボタンを作る

    チェック欄を削除 wsTodo
    チェック欄を削除 wsDone
    dailyAddCount = 毎日業務を追加する
    納期順に並び替える wsTodo
    納期順に並び替える wsDone
    チェック欄を作り直す wsTodo
    チェック欄を作り直す wsDone
    集計を更新

    wsInput.Activate
    wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Select

ExitPoint:
    Application.EnableEvents = True
    Application.ScreenUpdating = True
    Exit Sub

ErrHandler:
    MsgBox "初期設定で止まった。" & vbCrLf & Err.Description, vbExclamation
    Resume ExitPoint
End Sub

Public Sub Todoを追加()
    Dim wsInput As Worksheet
    Dim wsTodo As Worksheet
    Dim nextRow As Long

    On Error GoTo ErrHandler

    If Not 必要なシートがある Then
        MsgBox "先に「初期設定」を実行して。", vbExclamation
        Exit Sub
    End If

    Set wsInput = ThisWorkbook.Worksheets(INPUT_SHEET_NAME)
    Set wsTodo = ThisWorkbook.Worksheets(TODO_SHEET_NAME)

    If Len(Trim$(CStr(wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Value))) = 0 Then
        MsgBox "ToDo納期を選んで。", vbExclamation
        Exit Sub
    End If

    If Not IsDate(wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Value) Then
        MsgBox "ToDo納期が日付になってない。", vbExclamation
        Exit Sub
    End If

    If Len(Trim$(CStr(wsInput.Cells(INPUT_ROW, COL_ACTUAL_DATE).Value))) > 0 Then
        If Not IsDate(wsInput.Cells(INPUT_ROW, COL_ACTUAL_DATE).Value) Then
            MsgBox "実納期が日付になってない。", vbExclamation
            Exit Sub
        End If
    End If

    If Len(Trim$(CStr(wsInput.Cells(INPUT_ROW, COL_TASK).Value))) = 0 Then
        MsgBox "「行うこと」を入力して。", vbExclamation
        Exit Sub
    End If

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    チェック欄を削除 wsTodo

    nextRow = 次のデータ行(wsTodo)
    行の書式を整える wsTodo, nextRow

    wsTodo.Cells(nextRow, COL_TODO_DATE).Resize(1, 4).Value = _
        wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Resize(1, 4).Value
    wsTodo.Cells(nextRow, COL_CHECK).ClearContents

    wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Resize(1, 4).ClearContents

    納期順に並び替える wsTodo
    チェック欄を作り直す wsTodo
    集計を更新

    wsInput.Activate
    wsInput.Cells(INPUT_ROW, COL_TODO_DATE).Select
    MsgBox "ToDoリストに追加した。", vbInformation

ExitPoint:
    Application.EnableEvents = True
    Application.ScreenUpdating = True
    Exit Sub

ErrHandler:
    MsgBox "追加できなかった。" & vbCrLf & Err.Description, vbExclamation
    Resume ExitPoint
End Sub

