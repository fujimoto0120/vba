Public Sub 期限切れ完了行を削除()
    Dim ws As Worksheet
    Dim lastRow As Long
    Dim rowNo As Long
    Dim deleteCount As Long
    Dim answer As VbMsgBoxResult

    If Not 必要なシートがある Then
        MsgBox "先に「初期設定」を実行して。", vbExclamation
        Exit Sub
    End If

    Set ws = ThisWorkbook.Worksheets(DONE_SHEET_NAME)
    lastRow = ws.Cells(ws.Rows.Count, DELETE_DATE_COLUMN).End(xlUp).Row

    If lastRow < FIRST_DATA_ROW Then
        MsgBox "削除する完了データはない。", vbInformation
        Exit Sub
    End If

    answer = MsgBox( _
        "ToDo納期が昨日以前の完了データを削除する。" & vbCrLf & _
        "元に戻せないけど続ける？", _
        vbYesNo + vbExclamation, _
        "完了データの削除" _
    )

    If answer <> vbYes Then Exit Sub

    On Error GoTo ErrHandler

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    チェック欄を削除 ws

    For rowNo = lastRow To FIRST_DATA_ROW Step -1
        If IsDate(ws.Cells(rowNo, DELETE_DATE_COLUMN).Value) Then
            If DateValue(ws.Cells(rowNo, DELETE_DATE_COLUMN).Value) < Date Then
                ws.Cells(rowNo, COL_TODO_DATE).Resize(1, 5).Delete Shift:=xlUp
                deleteCount = deleteCount + 1
            End If
        End If
    Next rowNo

    納期順に並び替える ws
    チェック欄を作り直す ws
    集計を更新

    MsgBox deleteCount & "件削除した。", vbInformation

ExitPoint:
    Application.EnableEvents = True
    Application.ScreenUpdating = True
    Exit Sub

ErrHandler:
    MsgBox "削除の途中で止まった。" & vbCrLf & Err.Description, vbExclamation
    Resume ExitPoint
End Sub

Public Sub チェック切替()
    Dim sourceSheet As Worksheet
    Dim targetSheet As Worksheet
    Dim clickedShape As Shape
    Dim sourceRow As Long
    Dim targetRow As Long
    Dim callerName As String

    On Error GoTo ErrHandler

    callerName = CStr(Application.Caller)
    Set sourceSheet = ActiveSheet
    Set clickedShape = sourceSheet.Shapes(callerName)
    sourceRow = clickedShape.TopLeftCell.Row

    If sourceRow < FIRST_DATA_ROW Then Exit Sub
    If Not 行にデータがある(sourceSheet, sourceRow) Then Exit Sub

    If sourceSheet.Name = TODO_SHEET_NAME Then
        Set targetSheet = ThisWorkbook.Worksheets(DONE_SHEET_NAME)
    ElseIf sourceSheet.Name = DONE_SHEET_NAME Then
        Set targetSheet = ThisWorkbook.Worksheets(TODO_SHEET_NAME)
    Else
        Exit Sub
    End If

    Application.ScreenUpdating = False
    Application.EnableEvents = False

    チェック欄を削除 sourceSheet
    チェック欄を削除 targetSheet

    targetRow = 次のデータ行(targetSheet)
    行の書式を整える targetSheet, targetRow

    targetSheet.Cells(targetRow, COL_TODO_DATE).Resize(1, 4).Value = _
        sourceSheet.Cells(sourceRow, COL_TODO_DATE).Resize(1, 4).Value
    targetSheet.Cells(targetRow, COL_CHECK).ClearContents

    sourceSheet.Cells(sourceRow, COL_TODO_DATE).Resize(1, 5).Delete Shift:=xlUp

    納期順に並び替える sourceSheet
    納期順に並び替える targetSheet
    チェック欄を作り直す sourceSheet
    チェック欄を作り直す targetSheet
    集計を更新

ExitPoint:
    Application.EnableEvents = True
    Application.ScreenUpdating = True
    Exit Sub

ErrHandler:
    MsgBox "チェックの切り替えで止まった。" & vbCrLf & Err.Description, vbExclamation
    Resume ExitPoint
End Sub

Public Sub 日付候補を更新()
    Dim ws As Worksheet
    Dim d As Date
    Dim lastDate As Date
    Dim writeRow As Long
    Dim validationRange As Range

    Set ws = ThisWorkbook.Worksheets(INPUT_SHEET_NAME)

    ws.Columns(DATE_LIST_COLUMN).Hidden = False
    ws.Range( _
        ws.Cells(DATE_LIST_FIRST_ROW, DATE_LIST_COLUMN), _
        ws.Cells(DATE_LIST_FIRST_ROW + 40, DATE_LIST_COLUMN) _
    ).ClearContents

    d = Date
    lastDate = DateAdd("m", 1, Date)
    writeRow = DATE_LIST_FIRST_ROW

    Do While d <= lastDate
        ws.Cells(writeRow, DATE_LIST_COLUMN).Value = d
        ws.Cells(writeRow, DATE_LIST_COLUMN).NumberFormat = DATE_DISPLAY_FORMAT
        d = DateAdd("d", 1, d)
        writeRow = writeRow + 1
    Loop

    Set validationRange = ws.Cells(INPUT_ROW, COL_TODO_DATE).Resize(1, 2)

    With validationRange.Validation
        .Delete
        .Add Type:=xlValidateList, _
             AlertStyle:=xlValidAlertStop, _
             Operator:=xlBetween, _
             Formula1:="=" & _
                 ws.Cells(DATE_LIST_FIRST_ROW, DATE_LIST_COLUMN).Address & ":" & _
                 ws.Cells(writeRow - 1, DATE_LIST_COLUMN).Address
        .IgnoreBlank = True
        .InCellDropdown = True
        .InputTitle = "日付を選択"
        .InputMessage = "本日から1か月後まで"
        .ErrorTitle = "日付を確認"
        .ErrorMessage = "プルダウンの日付から選んで。"
        .ShowError = True
    End With

    validationRange.NumberFormat = DATE_DISPLAY_FORMAT
    ws.Columns(DATE_LIST_COLUMN).Hidden = True
End Sub

Public Sub 納期順に並び替える(ByVal ws As Worksheet)
    Dim lastRow As Long
    Dim rowNo As Long

    lastRow = 最終データ行(ws)
    If lastRow < FIRST_DATA_ROW Then Exit Sub

    ws.Range( _
        ws.Cells(HEADER_ROW, COL_TODO_DATE), _
        ws.Cells(lastRow, COL_CHECK) _
    ).Sort _
        Key1:=ws.Cells(FIRST_DATA_ROW, COL_TODO_DATE), _
        Order1:=xlAscending, _
        Header:=xlYes, _
        Orientation:=xlTopToBottom

    For rowNo = FIRST_DATA_ROW To lastRow
        If 行にデータがある(ws, rowNo) Then
            行の書式を整える ws, rowNo
        End If
    Next rowNo
End Sub

Public Sub チェック欄を作り直す(ByVal ws As Worksheet)
    Dim lastRow As Long
    Dim rowNo As Long
    Dim targetCell As Range
    Dim box As CheckBox
    Dim boxSize As Double
    Dim isDoneSheet As Boolean

    チェック欄を削除 ws

    lastRow = 最終データ行(ws)
    If lastRow < FIRST_DATA_ROW Then Exit Sub

    isDoneSheet = (ws.Name = DONE_SHEET_NAME)
    boxSize = 14

    For rowNo = FIRST_DATA_ROW To lastRow
        If 行にデータがある(ws, rowNo) Then
            Set targetCell = ws.Cells(rowNo, COL_CHECK)
            targetCell.ClearContents

            Set box = ws.CheckBoxes.Add( _
                targetCell.Left + (targetCell.Width - boxSize) / 2, _
                targetCell.Top + (targetCell.Height - boxSize) / 2, _
                boxSize, _
                boxSize _
            )

            With box
                .Caption = vbNullString
                .Name = CHECKBOX_PREFIX & Format$(rowNo, "00000")
                .OnAction = マクロ名を作る("チェック切替")
                .Placement = xlMoveAndSize
                If isDoneSheet Then
                    .Value = xlOn
                Else
                    .Value = xlOff
                End If
            End With
        End If
    Next rowNo
End Sub

Public Sub チェック欄を削除(ByVal ws As Worksheet)
    Dim i As Long

    For i = ws.CheckBoxes.Count To 1 Step -1
        If Left$(ws.CheckBoxes(i).Name, Len(CHECKBOX_PREFIX)) = CHECKBOX_PREFIX Then
            ws.CheckBoxes(i).Delete
        End If
    Next i
End Sub

