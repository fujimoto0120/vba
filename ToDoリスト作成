Private Sub 一覧シートの体裁を作る(ByVal ws As Worksheet, ByVal isDone As Boolean)
    Dim lastFormatRow As Long

    シートの基本設定 ws

    If isDone Then
        ws.Tab.Color = RGB(92, 158, 114)
    Else
        ws.Tab.Color = RGB(23, 50, 77)
    End If

    ws.Columns("A").ColumnWidth = 2.5
    ws.Columns("B").ColumnWidth = 15
    ws.Columns("C").ColumnWidth = 15
    ws.Columns("D").ColumnWidth = 10
    ws.Columns("E").ColumnWidth = 42
    ws.Columns("F").ColumnWidth = 11
    ws.Columns("G").ColumnWidth = 3
    ws.Columns("H:I").ColumnWidth = 13

    ws.Range("B1:I1").UnMerge
    ws.Range("B1:I1").Merge
    With ws.Range("B1:I1")
        If isDone Then
            .Value = "完了済み"
        Else
            .Value = "ToDoリスト"
        End If
        .Interior.Color = RGB(23, 50, 77)
        .Font.Name = "Yu Gothic"
        .Font.Size = 18
        .Font.Bold = True
        .Font.Color = RGB(255, 255, 255)
        .HorizontalAlignment = xlLeft
        .VerticalAlignment = xlVAlignCenter
    End With
    ws.Rows(1).RowHeight = 34

    ws.Cells(2, 2).Value = "ToDo納期"
    ws.Cells(2, 3).Value = "実納期"
    ws.Cells(2, 4).Value = "No"
    ws.Cells(2, 5).Value = "行うこと"
    ws.Cells(2, 6).Value = "チェック"
    見出しの書式 ws.Range("B2:F2")

    lastFormatRow = 最終データ行(ws)
    If lastFormatRow < 42 Then lastFormatRow = 42

    With ws.Range(ws.Cells(FIRST_DATA_ROW, COL_TODO_DATE), ws.Cells(lastFormatRow, COL_CHECK))
        .Interior.Color = RGB(255, 255, 255)
        .Font.Name = "Yu Gothic"
        .Font.Size = 10
        .Font.Color = RGB(36, 55, 70)
        .VerticalAlignment = xlVAlignCenter
        .Borders(xlInsideHorizontal).LineStyle = xlContinuous
        .Borders(xlInsideHorizontal).Color = RGB(215, 224, 229)
        .Borders(xlInsideHorizontal).Weight = xlThin
    End With

    ws.Range(ws.Cells(FIRST_DATA_ROW, COL_TODO_DATE), ws.Cells(lastFormatRow, COL_ACTUAL_DATE)).NumberFormat = DATE_DISPLAY_FORMAT
    ws.Range(ws.Cells(FIRST_DATA_ROW, COL_TODO_DATE), ws.Cells(lastFormatRow, COL_NO)).HorizontalAlignment = xlHAlignCenter
    ws.Range(ws.Cells(FIRST_DATA_ROW, COL_TASK), ws.Cells(lastFormatRow, COL_TASK)).WrapText = True
    ws.Range(ws.Cells(FIRST_DATA_ROW, COL_CHECK), ws.Cells(lastFormatRow, COL_CHECK)).HorizontalAlignment = xlHAlignCenter
    ws.Rows(FIRST_DATA_ROW & ":" & lastFormatRow).RowHeight = 24

    期限色を設定 ws

    If isDone Then
