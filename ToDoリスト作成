Private Function 毎日業務を追加する() As Long
    Dim wsDaily As Worksheet
    Dim wsTodo As Worksheet
    Dim lastRow As Long
    Dim rowNo As Long
    Dim targetRow As Long
    Dim taskText As String
    Dim statusText As String
    Dim shouldAdd As Boolean

    Set wsDaily = ThisWorkbook.Worksheets(DAILY_SHEET_NAME)
    Set wsTodo = ThisWorkbook.Worksheets(TODO_SHEET_NAME)

    lastRow = wsDaily.Cells(wsDaily.Rows.Count, COL_TASK).End(xlUp).Row
    If lastRow < FIRST_DATA_ROW Then Exit Function

    For rowNo = FIRST_DATA_ROW To lastRow
        taskText = Trim$(CStr(wsDaily.Cells(rowNo, COL_TASK).Value))

        If Len(taskText) > 0 Then
            wsDaily.Cells(rowNo, COL_TODO_DATE).Value = Date
            wsDaily.Cells(rowNo, COL_ACTUAL_DATE).Value = Date
            wsDaily.Cells(rowNo, COL_TODO_DATE).Resize(1, 2).NumberFormat = DATE_DISPLAY_FORMAT

            statusText = Trim$(CStr(wsDaily.Cells(rowNo, DAILY_STATUS_COLUMN).Value))
            If Len(statusText) = 0 Then
                statusText = DAILY_STATUS_ON
                wsDaily.Cells(rowNo, DAILY_STATUS_COLUMN).Value = statusText
            End If

            shouldAdd = (statusText <> DAILY_STATUS_OFF)

            If IsDate(wsDaily.Cells(rowNo, DAILY_LAST_DATE_COLUMN).Value) Then
                If DateValue(wsDaily.Cells(rowNo, DAILY_LAST_DATE_COLUMN).Value) = Date Then
                    shouldAdd = False
                End If
            End If

            If shouldAdd Then
                targetRow = 次のデータ行(wsTodo)
                行の書式を整える wsTodo, targetRow

                wsTodo.Cells(targetRow, COL_TODO_DATE).Value = Date
                wsTodo.Cells(targetRow, COL_ACTUAL_DATE).Value = Date
                wsTodo.Cells(targetRow, COL_NO).Value = wsDaily.Cells(rowNo, COL_NO).Value
                wsTodo.Cells(targetRow, COL_TASK).Value = wsDaily.Cells(rowNo, COL_TASK).Value
                wsTodo.Cells(targetRow, COL_CHECK).ClearContents

                wsDaily.Cells(rowNo, DAILY_LAST_DATE_COLUMN).Value = Date
                wsDaily.Cells(rowNo, DAILY_LAST_DATE_COLUMN).NumberFormat = DATE_DISPLAY_FORMAT
                毎日業務を追加する = 毎日業務を追加する + 1
            End If
        End If
    Next rowNo
End Function

Private Function シートを用意(ByVal targetName As String) As Worksheet
    Dim ws As Worksheet
    Dim resultSheet As Worksheet

    On Error Resume Next
    Set resultSheet = ThisWorkbook.Worksheets(targetName)
    On Error GoTo 0

    If Not resultSheet Is Nothing Then
        Set シートを用意 = resultSheet
        Exit Function
    End If

    ' 新しい空ブックなら、最初からある空シートをそのまま使う
    For Each ws In ThisWorkbook.Worksheets
        If Not ToDo用の名前か(ws.Name) Then
            If シートが空(ws) Then
                ws.Name = targetName
                Set シートを用意 = ws
                Exit Function
            End If
        End If
    Next ws

    ' 空きシートがなければ足す
    Set resultSheet = ThisWorkbook.Worksheets.Add( _
        After:=ThisWorkbook.Worksheets(ThisWorkbook.Worksheets.Count) _
    )
    resultSheet.Name = targetName
    Set シートを用意 = resultSheet
End Function

Private Function シートが空(ByVal ws As Worksheet) As Boolean
    シートが空 = _
        (Application.WorksheetFunction.CountA(ws.UsedRange) = 0) And _
        (ws.Shapes.Count = 0)
End Function

Private Function ToDo用の名前か(ByVal sheetName As String) As Boolean
    ToDo用の名前か = _
        (sheetName = INPUT_SHEET_NAME) Or _
        (sheetName = TODO_SHEET_NAME) Or _
        (sheetName = DONE_SHEET_NAME) Or _
        (sheetName = DAILY_SHEET_NAME)
End Function

Private Function 必要なシートがある() As Boolean
    Dim ws As Worksheet
    Dim foundCount As Long

    For Each ws In ThisWorkbook.Worksheets
        If ToDo用の名前か(ws.Name) Then foundCount = foundCount + 1
    Next ws

    必要なシートがある = (foundCount = 4)
End Function

