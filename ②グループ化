Option Explicit

' 設定シートのA列に出力列順、B列に合計対象列を記入して使います。
' A1とB1は見出し用です。実際の列名は2行目から空行を入れずに並べてください。
' B列には合計したい列を複数指定できます。
'
' このコードは、コードを保存したブックの「設定」シートを参照します。
' PERSONAL.XLSBやアドインへ入れる場合は、GetSettingsSheet内の
' ThisWorkbookをActiveWorkbookなどへ変更してください。

Private Const SETTINGS_SHEET_NAME As String = "設定"
Private Const OUTPUT_ORDER_COLUMN As Long = 1
Private Const SUM_TARGET_COLUMN As Long = 2
Private Const SETTINGS_START_ROW As Long = 2

' 日本語版Windowsで一般的なWindows-31J（CP932）として読み書きします。
' ADODB.Streamでは文字コード名をshift_jisと指定します。
Private Const INPUT_CHARSET As String = "shift_jis"
Private Const OUTPUT_CHARSET As String = "shift_jis"

Private Const CSV_DELIMITER As String = ","
Private Const DEFAULT_OUTPUT_SUFFIX As String = "_grouped"

' Trueなら合計列の空欄を0として扱います。
' Falseにすると、空欄を見つけた時点で処理を中止します。
Private Const BLANK_SUM_VALUE_IS_ZERO As Boolean = True

' 合計列で許可する数値書式です。
' 1234、1,234、-123.45、.5などを許可し、指数表記や通貨記号は許可しません。
Private Const DECIMAL_VALUE_PATTERN As String = _
    "^[+-]?(((\d{1,3}(,\d{3})+)|\d+)(\.\d+)?|\.\d+)$"

' 見出し名は大文字と小文字を区別せずに照合します。
' グループ化する値は、英字の大小や前後の空白も含めて区別します。
Private Const HEADER_COMPARE_MODE As Long = 1
Private Const GROUP_COMPARE_MODE As Long = 0

' ADODB.Streamを遅延バインディングで使うため、必要な定数だけ定義します。
' Excelの参照設定を追加する必要はありません。
Private Const AD_TYPE_TEXT As Long = 2
Private Const AD_WRITE_LINE As Long = 1
Private Const AD_SAVE_CREATE_OVERWRITE As Long = 2
Private Const AD_CRLF As Long = -1

Public Sub GroupShiftJisCsvAndSave_MultiSum()
    Dim outputHeaders() As String
    Dim sumHeaders() As String
    Dim sourceIndexes() As Long
    Dim isSumColumn() As Boolean
    Dim inputPath As String
    Dim outputPath As String
    Dim csvText As String
    Dim records As Collection
    Dim groups As Object
    Dim groupOrder As Collection
    Dim inputDataCount As Long
    Dim errorNumber As Long
    Dim errorDescription As String

    On Error GoTo Failed

    ' ファイルを選ぶ前に設定を検証します。
    ' 設定ミスがある場合、不要なファイル選択をさせないためです。
    ReadSettings outputHeaders, sumHeaders

    inputPath = ChooseInputCsvPath()
    If Len(inputPath) = 0 Then Exit Sub

    outputPath = ChooseOutputCsvPath(inputPath)
    If Len(outputPath) = 0 Then Exit Sub

    Application.StatusBar = "Shift_JISのCSVを読み込んでいます..."
    csvText = ReadTextFile(inputPath, INPUT_CHARSET)

    ' CSVをExcelシートへ開くと、先頭ゼロや日付らしい値が自動変換されます。
    ' それを避けるため、文字列のままCSVのレコードを解析します。
    Application.StatusBar = "CSVの内容を確認しています..."
    Set records = ParseCsvRecords(csvText)
    csvText = vbNullString

    ' 設定シートの列順と、CSV内の実際の列位置を対応付けます。
    ' 合計対象かどうかもこの時点で列ごとに記録します。
    BuildColumnLayout records, outputHeaders, sumHeaders, _
                      sourceIndexes, isSumColumn

    Application.StatusBar = "データをグループ化して集計しています..."
    AggregateRecords records, outputHeaders, sourceIndexes, _
                     isSumColumn, groups, groupOrder, inputDataCount

    Application.StatusBar = "集計結果をShift_JISで保存しています..."
    WriteGroupedCsv outputPath, outputHeaders, isSumColumn, _
                    groups, groupOrder

    Application.StatusBar = False

    MsgBox "集計が完了しました。" & vbCrLf & _
           "入力データ件数: " & Format$(inputDataCount, "#,##0") & vbCrLf & _
           "出力グループ数: " & Format$(groups.Count, "#,##0") & vbCrLf & _
           "合計対象列数: " & Format$(StringArrayCount(sumHeaders), "#,##0") & vbCrLf & _
           "合計対象列: " & Join(sumHeaders, "、") & vbCrLf & _
           "保存先: " & outputPath, _
           vbInformation, "CSVグループ集計"
    Exit Sub

Failed:
    errorNumber = Err.Number
    errorDescription = Err.Description
    Application.StatusBar = False

    MsgBox "処理を中止しました。" & vbCrLf & _
           errorDescription & vbCrLf & _
           "エラー番号: " & CStr(errorNumber), _
           vbCritical, "CSVグループ集計"
End Sub

' 設定シートから出力列と合計列を読み取ります。
' 列名一覧を読む処理はReadNameListにまとめ、A列とB列で同じ検証を行います。
Private Sub ReadSettings(ByRef outputHeaders() As String, _
                         ByRef sumHeaders() As String)
    Dim ws As Worksheet
    Dim outputHeaderSet As Object
    Dim index As Long

    Set ws = GetSettingsSheet()

    ReadNameList ws, OUTPUT_ORDER_COLUMN, _
                 "出力列一覧（A列）", outputHeaders

    ReadNameList ws, SUM_TARGET_COLUMN, _
                 "合計対象列一覧（B列）", sumHeaders

    ' 合計対象列は出力列一覧にも必要です。
    ' A列にない列をB列だけに指定すると、出力位置を決められないため停止します。
    Set outputHeaderSet = CreateNameSet(outputHeaders)

    For index = LBound(sumHeaders) To UBound(sumHeaders)
        If Not outputHeaderSet.Exists(sumHeaders(index)) Then
            RaiseUserError "合計対象列「" & sumHeaders(index) & _
                           "」が設定シートA列の出力列一覧にありません。"
        End If
    Next index
End Sub

' 指定された列の2行目から最終入力行までを、列名一覧として読み取ります。
' 途中の空行と列名の重複は、設定ミスとして扱います。
Private Sub ReadNameList(ByVal ws As Worksheet, _
                         ByVal columnNumber As Long, _
                         ByVal listName As String, _
                         ByRef result() As String)
    Dim lastRow As Long
    Dim rowNumber As Long
    Dim itemCount As Long
    Dim cellValue As Variant
    Dim columnName As String
    Dim seen As Object

    lastRow = ws.Cells(ws.rows.Count, columnNumber).End(xlUp).Row

    If lastRow < SETTINGS_START_ROW Then
        RaiseUserError "設定シートの" & listName & _
                       "に列名が入力されていません。"
    End If

    ReDim result(0 To lastRow - SETTINGS_START_ROW)

    Set seen = CreateObject("Scripting.Dictionary")
    seen.CompareMode = HEADER_COMPARE_MODE

    For rowNumber = SETTINGS_START_ROW To lastRow
        cellValue = ws.Cells(rowNumber, columnNumber).Value2

        If IsError(cellValue) Then
            RaiseUserError "設定シートの" & _
                           ws.Cells(rowNumber, columnNumber).Address(False, False) & _
                           "がExcelエラー値です。"
        End If

        columnName = NormalizeHeaderName(CStr(cellValue))

        If Len(columnName) = 0 Then
            RaiseUserError "設定シートの" & listName & _
                           "に空行があります。" & vbCrLf & _
                           "2行目から最終入力行までは空行を入れないでください。" & _
                           vbCrLf & "対象セル: " & _
                           ws.Cells(rowNumber, columnNumber).Address(False, False)
        End If

        If seen.Exists(columnName) Then
            RaiseUserError "設定シートの" & listName & _
                           "で列名が重複しています: " & columnName
        End If

        seen.Add columnName, True
        result(itemCount) = columnName
        itemCount = itemCount + 1
    Next rowNumber
End Sub

' マクロを保存しているブックから設定シートを取得します。
' PERSONAL.XLSBなどから実行するときに変更が必要なのは、主にこの関数です。
Private Function GetSettingsSheet() As Worksheet
    Dim ws As Worksheet

    On Error Resume Next
    Set ws = ThisWorkbook.Worksheets(SETTINGS_SHEET_NAME)
    On Error GoTo 0

    If ws Is Nothing Then
        RaiseUserError "シート「" & SETTINGS_SHEET_NAME & _
                       "」が見つかりません。"
    End If

    Set GetSettingsSheet = ws
End Function

' 読み込むCSVをユーザーに選んでもらいます。
' キャンセルされた場合は空文字を返し、メイン処理を静かに終了します。
Private Function ChooseInputCsvPath() As String
    Dim selectedPath As Variant

    selectedPath = Application.GetOpenFilename( _
        FileFilter:="CSVファイル (*.csv),*.csv,すべてのファイル (*.*),*.*", _
        Title:="グループ化するShift_JISのCSVを選択してください", _
        MultiSelect:=False)

    If VarType(selectedPath) = vbBoolean Then
        ChooseInputCsvPath = vbNullString
    Else
        ChooseInputCsvPath = CStr(selectedPath)
    End If
End Function

' 集計結果の保存先を選んでもらいます。
' 元のCSVを誤って消さないように、入力ファイルと同じ場所は受け付けません。
Private Function ChooseOutputCsvPath(ByVal inputPath As String) As String
    Dim selectedPath As Variant
    Dim initialPath As String
    Dim candidatePath As String

    initialPath = BuildDefaultOutputPath(inputPath)

    Do
        selectedPath = Application.GetSaveAsFilename( _
            InitialFileName:=initialPath, _
            FileFilter:="CSVファイル (*.csv),*.csv", _
            Title:="集計後のShift_JIS CSVの保存先を指定してください")

        If VarType(selectedPath) = vbBoolean Then
            ChooseOutputCsvPath = vbNullString
            Exit Function
        End If

        candidatePath = CStr(selectedPath)

        ' 拡張子を省略した場合だけ.csvを補います。
        If LCase$(Right$(candidatePath, 4)) <> ".csv" Then
            candidatePath = candidatePath & ".csv"
        End If

        If SamePath(candidatePath, inputPath) Then
            MsgBox "入力CSVと同じファイルには上書きできません。" & vbCrLf & _
                   "別の保存先を指定してください。", _
                   vbExclamation, "CSVグループ集計"
            initialPath = candidatePath
        Else
            ChooseOutputCsvPath = candidatePath
            Exit Function
        End If
    Loop
End Function

' 入力ファイル名の末尾に_groupedを付けた名前を、保存時の初期値にします。
Private Function BuildDefaultOutputPath(ByVal inputPath As String) As String
    Dim fso As Object
    Dim parentFolder As String
    Dim baseName As String

    Set fso = CreateObject("Scripting.FileSystemObject")
    parentFolder = fso.GetParentFolderName(inputPath)
    baseName = fso.GetBaseName(inputPath)

    BuildDefaultOutputPath = fso.BuildPath( _
        parentFolder, baseName & DEFAULT_OUTPUT_SUFFIX & ".csv")
End Function

' 相対表記や英字の大小が違っていても、同じパスならTrueを返します。
Private Function SamePath(ByVal firstPath As String, _
                          ByVal secondPath As String) As Boolean
    Dim fso As Object
    Dim firstAbsolute As String
    Dim secondAbsolute As String

    Set fso = CreateObject("Scripting.FileSystemObject")
    firstAbsolute = fso.GetAbsolutePathName(firstPath)
    secondAbsolute = fso.GetAbsolutePathName(secondPath)

    SamePath = (StrComp(firstAbsolute, secondAbsolute, _
                        vbTextCompare) = 0)
End Function

' ADODB.Streamを使って、指定した文字コードのテキストを読み込みます。
' 参照設定は不要ですが、Windows上でADODB.Streamが利用できることが前提です。
Private Function ReadTextFile(ByVal filePath As String, _
                              ByVal charsetName As String) As String
    Dim stream As Object
    Dim errorNumber As Long
    Dim errorDescription As String

    On Error GoTo Failed

    Set stream = CreateObject("ADODB.Stream")
    stream.Type = AD_TYPE_TEXT
    stream.Charset = charsetName
    stream.Open
    stream.LoadFromFile filePath

    ReadTextFile = stream.ReadText
    stream.Close
    Exit Function

Failed:
    errorNumber = Err.Number
    errorDescription = Err.Description

    On Error Resume Next
    If Not stream Is Nothing Then stream.Close
    On Error GoTo 0

    Err.Raise errorNumber, "ReadTextFile", _
              "CSVを読み込めませんでした: " & filePath & vbCrLf & _
              errorDescription
End Function

' CSV全体をレコード単位に分解します。
' 単純なSplitでは扱えない、引用符内のカンマや改行にも対応しています。
' 二重引用符を2個続けた表記は、1個の引用符として読み取ります。
Private Function ParseCsvRecords(ByVal csvText As String) As Collection
    Dim records As New Collection
    Dim fields As New Collection
    Dim fieldValue As String
    Dim character As String
    Dim position As Long
    Dim textLength As Long
    Dim inQuotes As Boolean
    Dim fieldStarted As Boolean
    Dim recordStarted As Boolean
    Dim afterClosingQuote As Boolean

    textLength = Len(csvText)
    position = 1

    Do While position <= textLength
        character = Mid$(csvText, position, 1)

        If inQuotes Then
            If character = """" Then
                ' 引用符内で引用符が2個続いた場合は、データとしての引用符です。
                If position < textLength And _
                   Mid$(csvText, position + 1, 1) = """" Then
                    fieldValue = fieldValue & """"
                    position = position + 1
                Else
                    inQuotes = False
                    afterClosingQuote = True
                End If
            Else
                ' 引用符内ならカンマや改行もそのまま値へ含めます。
                fieldValue = fieldValue & character
            End If
        Else
            Select Case character
                Case """"
                    ' 項目の途中から引用符が始まる形式は、曖昧なので受け付けません。
                    If fieldStarted Or afterClosingQuote Then
                        RaiseUserError "CSVレコード" & _
                            CStr(records.Count + 1) & _
                            "の引用符の位置が不正です。"
                    End If

                    inQuotes = True
                    fieldStarted = True
                    recordStarted = True

                Case CSV_DELIMITER
                    ' カンマが来たら現在の項目を確定し、次の項目へ進みます。
                    fields.Add fieldValue
                    fieldValue = vbNullString
                    fieldStarted = False
                    afterClosingQuote = False
                    recordStarted = True

                Case vbCr, vbLf
                    ' 値を何も持たない物理的な空行は読み飛ばします。
                    If recordStarted Or fields.Count > 0 Or _
                       Len(fieldValue) > 0 Then
                        fields.Add fieldValue
                        records.Add CollectionToStringArray(fields)
                    End If

                    Set fields = New Collection
                    fieldValue = vbNullString
                    fieldStarted = False
                    recordStarted = False
                    afterClosingQuote = False

                    ' CRLFは2文字で1つの改行なので、LF側を重ねて処理しません。
                    If character = vbCr And position < textLength Then
                        If Mid$(csvText, position + 1, 1) = vbLf Then
                            position = position + 1
                        End If
                    End If

                Case Else
                    ' 閉じ引用符の直後に文字が続くCSVは、不正な形式として止めます。
                    If afterClosingQuote Then
                        RaiseUserError "CSVレコード" & _
                            CStr(records.Count + 1) & _
                            "で、閉じ引用符の後に不正な文字があります。"
                    End If

                    fieldValue = fieldValue & character
                    fieldStarted = True
                    recordStarted = True
            End Select
        End If

        position = position + 1
    Loop

    If inQuotes Then
        RaiseUserError "CSVレコード" & CStr(records.Count + 1) & _
                       "の引用符が閉じていません。"
    End If

    ' ファイル末尾に改行がない場合は、ここで最後のレコードを確定します。
    If recordStarted Or fields.Count > 0 Or Len(fieldValue) > 0 Then
        fields.Add fieldValue
        records.Add CollectionToStringArray(fields)
    End If

    Set ParseCsvRecords = records
End Function

' Collectionへ一時保存した1レコード分の項目を、扱いやすい配列へ変換します。
Private Function CollectionToStringArray(ByVal values As Collection) As Variant
    Dim result() As String
    Dim index As Long

    ReDim result(0 To values.Count - 1)

    For index = 1 To values.Count
        result(index - 1) = CStr(values(index))
    Next index

    CollectionToStringArray = result
End Function

' CSVの見出しと設定シートの列名を照合し、列位置を確定します。
' sourceIndexesには、出力列ごとのCSV内の位置を保存します。
' isSumColumnには、各出力列が合計対象かどうかを保存します。
Private Sub BuildColumnLayout(ByVal records As Collection, _
                              ByRef outputHeaders() As String, _
                              ByRef sumHeaders() As String, _
                              ByRef sourceIndexes() As Long, _
                              ByRef isSumColumn() As Boolean)
    Dim sourceHeader As Variant
    Dim headerMap As Object
    Dim sumHeaderSet As Object
    Dim sourceColumnCount As Long
    Dim outputColumnCount As Long
    Dim outputIndex As Long

    If records.Count = 0 Then
        RaiseUserError "CSVに見出し行がありません。"
    End If

    sourceHeader = records(1)
    sourceColumnCount = VariantArrayCount(sourceHeader)
    outputColumnCount = StringArrayCount(outputHeaders)

    Set headerMap = CreateCsvHeaderMap(sourceHeader)

    ' 前処理マクロと設定シートがずれている場合は、ここで確実に止めます。
    ' 余分な列を黙って捨てる動作にはしていません。
    If sourceColumnCount <> outputColumnCount Then
        RaiseUserError "設定シートA列とCSVの列数が一致しません。" & _
                       vbCrLf & "設定: " & CStr(outputColumnCount) & _
                       "列 / CSV: " & CStr(sourceColumnCount) & "列"
    End If

    Set sumHeaderSet = CreateNameSet(sumHeaders)

    ReDim sourceIndexes(LBound(outputHeaders) To UBound(outputHeaders))
    ReDim isSumColumn(LBound(outputHeaders) To UBound(outputHeaders))

    For outputIndex = LBound(outputHeaders) To UBound(outputHeaders)
        If Not headerMap.Exists(outputHeaders(outputIndex)) Then
            RaiseUserError "設定シートにある列がCSVにありません: " & _
                           outputHeaders(outputIndex)
        End If

        sourceIndexes(outputIndex) = _
            CLng(headerMap(outputHeaders(outputIndex)))

        isSumColumn(outputIndex) = _
            sumHeaderSet.Exists(outputHeaders(outputIndex))
    Next outputIndex
End Sub

' CSV見出しから、列名をキー、CSV内の列位置を値とする辞書を作ります。
' 空の見出しや重複見出しは、列の特定ができないためエラーにします。
Private Function CreateCsvHeaderMap(ByVal sourceHeader As Variant) As Object
    Dim headerMap As Object
    Dim sourceIndex As Long
    Dim normalizedName As String

    Set headerMap = CreateObject("Scripting.Dictionary")
    headerMap.CompareMode = HEADER_COMPARE_MODE

    For sourceIndex = LBound(sourceHeader) To UBound(sourceHeader)
        normalizedName = NormalizeHeaderName( _
            CStr(sourceHeader(sourceIndex)))

        If Len(normalizedName) = 0 Then
            RaiseUserError "CSVの見出しに空欄があります。列番号: " & _
                           CStr(sourceIndex - LBound(sourceHeader) + 1)
        End If

        If headerMap.Exists(normalizedName) Then
            RaiseUserError "CSVの見出しが重複しています: " & _
                           normalizedName
        End If

        headerMap.Add normalizedName, sourceIndex
    Next sourceIndex

    Set CreateCsvHeaderMap = headerMap
End Function

' 列名配列を検索しやすい辞書へ変換します。
' 見出し名と同じく、大文字と小文字は区別しません。
Private Function CreateNameSet(ByRef names() As String) As Object
    Dim nameSet As Object
    Dim index As Long

    Set nameSet = CreateObject("Scripting.Dictionary")
    nameSet.CompareMode = HEADER_COMPARE_MODE

    For index = LBound(names) To UBound(names)
        nameSet.Add names(index), True
    Next index

    Set CreateNameSet = nameSet
End Function

' すべてのデータ行を読み、合計対象ではない列をキーにして集計します。
' B列で指定した複数の合計列は、同じグループ内でそれぞれ加算します。
Private Sub AggregateRecords(ByVal records As Collection, _
                             ByRef outputHeaders() As String, _
                             ByRef sourceIndexes() As Long, _
                             ByRef isSumColumn() As Boolean, _
                             ByRef groups As Object, _
                             ByRef groupOrder As Collection, _
                             ByRef inputDataCount As Long)
    Dim recordNumber As Long
    Dim expectedColumnCount As Long
    Dim headerRow As Variant
    Dim rowData As Variant
    Dim groupKey As String
    Dim groupedRow As Variant
    Dim newRow() As Variant
    Dim outputIndex As Long
    Dim amount As Variant

    Set groups = CreateObject("Scripting.Dictionary")
    groups.CompareMode = GROUP_COMPARE_MODE

    ' Dictionaryの列挙順には依存せず、初出順をCollectionで明示的に保持します。
    Set groupOrder = New Collection

    headerRow = records(1)
    expectedColumnCount = VariantArrayCount(headerRow)

    For recordNumber = 2 To records.Count
        rowData = records(recordNumber)

        ' 行ごとに列数を確認し、不完全なデータを合計へ混ぜないようにします。
        If VariantArrayCount(rowData) <> expectedColumnCount Then
            RaiseUserError "CSVレコード" & CStr(recordNumber) & _
                           "の列数が見出しと一致しません。" & _
                           vbCrLf & "見出し: " & _
                           CStr(expectedColumnCount) & "列 / データ: " & _
                           CStr(VariantArrayCount(rowData)) & "列"
        End If

        groupKey = BuildGroupKey( _
            rowData, sourceIndexes, isSumColumn)

        If groups.Exists(groupKey) Then
            groupedRow = groups(groupKey)

            ' 既存グループなら、指定された合計列だけを1列ずつ加算します。
            For outputIndex = LBound(outputHeaders) To UBound(outputHeaders)
                If isSumColumn(outputIndex) Then
                    amount = ParseDecimalAmount( _
                        CStr(rowData(sourceIndexes(outputIndex))), _
                        recordNumber, outputHeaders(outputIndex))

                    groupedRow(outputIndex) = AddDecimalValues( _
                        groupedRow(outputIndex), amount, _
                        recordNumber, outputHeaders(outputIndex))
                End If
            Next outputIndex

            ' 配列は取り出したコピーなので、変更後に辞書へ戻します。
            groups(groupKey) = groupedRow
        Else
            ReDim newRow(LBound(outputHeaders) To UBound(outputHeaders))

            ' 新しいグループでは、キー列を文字列のまま保存します。
            ' 合計列は最初の値をDecimal型へ変換して初期値にします。
            For outputIndex = LBound(outputHeaders) To UBound(outputHeaders)
                If isSumColumn(outputIndex) Then
                    newRow(outputIndex) = ParseDecimalAmount( _
                        CStr(rowData(sourceIndexes(outputIndex))), _
                        recordNumber, outputHeaders(outputIndex))
                Else
                    newRow(outputIndex) = CStr( _
                        rowData(sourceIndexes(outputIndex)))
                End If
            Next outputIndex

            groups.Add groupKey, newRow
            groupOrder.Add groupKey
        End If

        inputDataCount = inputDataCount + 1

        ' 大きめのCSVでもExcelが完全に無応答に見えないよう、進捗を更新します。
        If inputDataCount Mod 10000 = 0 Then
            Application.StatusBar = "データを集計しています... " & _
                                    Format$(inputDataCount, "#,##0") & "件"
            DoEvents
        End If
    Next recordNumber
End Sub

' 合計対象ではない列だけを連結し、グループを識別するキーを作ります。
' 値の文字数も含めるため、値の中に「|」や「:」があっても衝突しません。
Private Function BuildGroupKey(ByVal rowData As Variant, _
                               ByRef sourceIndexes() As Long, _
                               ByRef isSumColumn() As Boolean) As String
    Dim outputIndex As Long
    Dim value As String
    Dim key As String

    key = "G|"

    For outputIndex = LBound(sourceIndexes) To UBound(sourceIndexes)
        If Not isSumColumn(outputIndex) Then
            value = CStr(rowData(sourceIndexes(outputIndex)))
            key = key & CStr(Len(value)) & ":" & value & "|"
        End If
    Next outputIndex

    ' 全列が合計対象ならキーは常にG|となり、全行が1グループになります。
    BuildGroupKey = key
End Function

' CSVに書かれた数値をDecimal型へ変換します。
' Double型よりも、金額や小数の合計で丸め誤差が出にくい型を選んでいます。
Private Function ParseDecimalAmount(ByVal rawValue As String, _
                                    ByVal recordNumber As Long, _
                                    ByVal columnName As String) As Variant
    Static numberPattern As Object
    Dim value As String
    Dim conversionValue As String
    Dim localDecimalSeparator As String
    Dim errorDescription As String

    value = Trim$(rawValue)

    If Len(value) = 0 Then
        If BLANK_SUM_VALUE_IS_ZERO Then
            ParseDecimalAmount = CDec(0)
            Exit Function
        Else
            RaiseUserError "CSVレコード" & CStr(recordNumber) & _
                           "の合計列「" & columnName & "」が空欄です。"
        End If
    End If

    ' 正規表現は最初の1回だけ作り、行ごとに作り直さないようにします。
    If numberPattern Is Nothing Then
        Set numberPattern = CreateObject("VBScript.RegExp")
        numberPattern.Global = False
        numberPattern.IgnoreCase = True
        numberPattern.Pattern = DECIMAL_VALUE_PATTERN
    End If

    If Not numberPattern.Test(value) Then
        RaiseUserError "CSVレコード" & CStr(recordNumber) & _
                       "の合計列「" & columnName & _
                       "」が数値ではありません: " & rawValue
    End If

    ' 3桁区切りのカンマを除き、Excelの小数点記号に合わせてから変換します。
    conversionValue = Replace$(value, ",", vbNullString)
    localDecimalSeparator = CStr( _
        Application.International(xlDecimalSeparator))

    If localDecimalSeparator <> "." Then
        conversionValue = Replace$(conversionValue, ".", _
                                   localDecimalSeparator)
    End If

    On Error GoTo ConversionFailed
    ParseDecimalAmount = CDec(conversionValue)
    On Error GoTo 0
    Exit Function

ConversionFailed:
    errorDescription = Err.Description
    On Error GoTo 0

    RaiseUserError "CSVレコード" & CStr(recordNumber) & _
                   "の合計列「" & columnName & _
                   "」をDecimal型へ変換できません: " & rawValue & _
                   vbCrLf & errorDescription
End Function

' 2つのDecimal値を加算します。
' 列名をエラーへ含めることで、複数合計列のどこで失敗したか分かるようにします。
Private Function AddDecimalValues(ByVal firstValue As Variant, _
                                  ByVal secondValue As Variant, _
                                  ByVal recordNumber As Long, _
                                  ByVal columnName As String) As Variant
    Dim errorDescription As String

    On Error GoTo AdditionFailed
    AddDecimalValues = CDec(firstValue) + CDec(secondValue)
    On Error GoTo 0
    Exit Function

AdditionFailed:
    errorDescription = Err.Description
    On Error GoTo 0

    RaiseUserError "CSVレコード" & CStr(recordNumber) & _
                   "の合計列「" & columnName & _
                   "」を加算中に桁あふれが発生しました。" & vbCrLf & _
                   errorDescription
End Function

' 集計済みのデータを、Shift_JISのCSVとして保存します。
' ADODB.Streamへ1行ずつ書くため、出力用の巨大な文字列は作りません。
Private Sub WriteGroupedCsv(ByVal outputPath As String, _
                            ByRef outputHeaders() As String, _
                            ByRef isSumColumn() As Boolean, _
                            ByVal groups As Object, _
                            ByVal groupOrder As Collection)
    Dim stream As Object
    Dim orderIndex As Long
    Dim groupedRow As Variant
    Dim errorNumber As Long
    Dim errorDescription As String

    On Error GoTo Failed

    Set stream = CreateObject("ADODB.Stream")
    stream.Type = AD_TYPE_TEXT
    stream.Charset = OUTPUT_CHARSET
    stream.Open
    stream.LineSeparator = AD_CRLF

    stream.WriteText BuildHeaderCsvLine(outputHeaders), AD_WRITE_LINE

    For orderIndex = 1 To groupOrder.Count
        groupedRow = groups(groupOrder(orderIndex))
        stream.WriteText BuildDataCsvLine( _
            groupedRow, isSumColumn), AD_WRITE_LINE
    Next orderIndex

    stream.SaveToFile outputPath, AD_SAVE_CREATE_OVERWRITE
    stream.Close
    Exit Sub

Failed:
    errorNumber = Err.Number
    errorDescription = Err.Description

    On Error Resume Next
    If Not stream Is Nothing Then stream.Close
    On Error GoTo 0

    Err.Raise errorNumber, "WriteGroupedCsv", _
              "CSVを保存できませんでした: " & outputPath & vbCrLf & _
              errorDescription
End Sub

' 設定シートA列の並びで、CSVの見出し行を作ります。
Private Function BuildHeaderCsvLine( _
    ByRef outputHeaders() As String) As String

    Dim escapedFields() As String
    Dim index As Long

    ReDim escapedFields(LBound(outputHeaders) To UBound(outputHeaders))

    For index = LBound(outputHeaders) To UBound(outputHeaders)
        escapedFields(index) = EscapeCsvField(outputHeaders(index))
    Next index

    BuildHeaderCsvLine = Join(escapedFields, CSV_DELIMITER)
End Function

' 集計結果の1行をCSV形式へ変換します。
' 合計列だけ数値用の書式へ戻し、キー列は元の文字列をそのまま使います。
Private Function BuildDataCsvLine(ByVal groupedRow As Variant, _
                                  ByRef isSumColumn() As Boolean) As String
    Dim escapedFields() As String
    Dim index As Long
    Dim value As String

    ReDim escapedFields(LBound(groupedRow) To UBound(groupedRow))

    For index = LBound(groupedRow) To UBound(groupedRow)
        If isSumColumn(index) Then
            value = DecimalToInvariantText(groupedRow(index))
        Else
            value = CStr(groupedRow(index))
        End If

        escapedFields(index) = EscapeCsvField(value)
    Next index

    BuildDataCsvLine = Join(escapedFields, CSV_DELIMITER)
End Function

' カンマ、引用符、改行を含む項目は引用符で囲みます。
' 項目内の引用符は2個へ置き換え、一般的なCSV形式で保存します。
Private Function EscapeCsvField(ByVal value As String) As String
    Dim needsQuotes As Boolean

    needsQuotes = (InStr(1, value, CSV_DELIMITER, vbBinaryCompare) > 0) _
                  Or (InStr(1, value, """", vbBinaryCompare) > 0) _
                  Or (InStr(1, value, vbCr, vbBinaryCompare) > 0) _
                  Or (InStr(1, value, vbLf, vbBinaryCompare) > 0)

    ' 前後の半角空白も、他のソフトで削られにくいよう引用符で囲みます。
    If Len(value) > 0 Then
        needsQuotes = needsQuotes _
                      Or (Left$(value, 1) = " ") _
                      Or (Right$(value, 1) = " ")
    End If

    If needsQuotes Then
        EscapeCsvField = """" & _
                         Replace$(value, """", """""") & """"
    Else
        EscapeCsvField = value
    End If
End Function

' 出力する小数点をピリオドへ統一します。
' CStrはExcelの地域設定を使うため、そのままだと環境によって小数点が変わるためです。
Private Function DecimalToInvariantText(ByVal value As Variant) As String
    Dim result As String
    Dim localDecimalSeparator As String

    result = CStr(CDec(value))
    localDecimalSeparator = CStr( _
        Application.International(xlDecimalSeparator))

    If localDecimalSeparator <> "." Then
        result = Replace$(result, localDecimalSeparator, ".")
    End If

    DecimalToInvariantText = result
End Function

' 見出しの前後に誤って入った半角空白は取り除いて照合します。
' UTF系のBOMが先頭に入っていた場合も、最初の見出しから除去します。
Private Function NormalizeHeaderName(ByVal value As String) As String
    value = Trim$(value)

    If Len(value) > 0 Then
        ' AscWではU+FEFFが符号付きの-257として返されます。
        If AscW(Left$(value, 1)) = -257 Then
            value = Mid$(value, 2)
        End If
    End If

    NormalizeHeaderName = value
End Function

' String型の1次元配列の要素数を返します。
' LBoundが0以外の配列でも正しい件数になるように計算します。
Private Function StringArrayCount(ByRef values() As String) As Long
    StringArrayCount = UBound(values) - LBound(values) + 1
End Function

' CSV解析後のVariant配列について、同じ方法で要素数を返します。
' 型付き配列とVariant配列を分け、VBAの配列引数による型不一致を避けています。
Private Function VariantArrayCount(ByVal values As Variant) As Long
    VariantArrayCount = UBound(values) - LBound(values) + 1
End Function

' 想定できる入力ミスは、同じ形式のメッセージでメイン処理へ返します。
Private Sub RaiseUserError(ByVal message As String)
    Err.Raise vbObjectError + 2101, "CSVグループ集計", message
End Sub
